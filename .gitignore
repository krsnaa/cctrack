# Binary (root-anchored so cmd/usage-probe/ source dir is not ignored)
/cctrack
/usage-probe

# Local Go caches used when the default ~/Library/Caches/go-build and
# ~/go/pkg/mod paths are not writable (sandboxed environments).
.gocache/
.gomodcache/

# Dependencies
web/node_modules/

# Build output (embedded via go:embed, but regenerated)
web/dist/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Commit-message scratch file for sandbox-bounded commits (ephemeral).
.commitmsg-*
